<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Announcements | CHCC Admin</title>
  <meta name="description" content="Manage school announcements and notices for students.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Nunito', sans-serif;
      background: #f8fafc;
      color: #0f172a;
      height: 100vh;
      display: flex;
      overflow: hidden;
    }
    
    /* Sidebar */
    .sidebar {
      width: 250px;
      background: #1e293b;
      color: #fff;
      display: flex; flex-direction: column;
      padding: 24px 16px;
      z-index: 10;
    }
    .sb-logo-box { display: flex; gap: 12px; align-items: center; margin-bottom: 40px; padding: 0 10px; }
    .sb-logo { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
    .sb-title { font-family: 'Outfit'; font-size: 14px; font-weight: 800; line-height: 1.2; letter-spacing: 0.5px; }
    .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px; border-radius: 12px;
      color: #94a3b8; text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 6px;
      transition: 0.2s;
    }
    .nav-link:hover { background: #334155; color: #fff; }
    .nav-link.active { background: #38bdf8; color: #0f172a; }
    .sb-footer { margin-top: auto; border-top: 1px solid #334155; padding-top: 24px; }
    .logout-btn { display: block; width: 100%; text-align: center; padding: 10px; background: #ef4444; color: #fff; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 14px; transition: 0.2s; }
    .logout-btn:hover { background: #dc2626; }
    
    /* Main */
    .main-content {
      flex: 1; display: flex; flex-direction: column; overflow-y: auto;
    }
    .topbar {
      background: #fff; padding: 24px 40px; border-bottom: 1px solid #e2e8f0;
      display: flex; justify-content: space-between; align-items: center;
    }
    .page-title { font-family: 'Outfit'; font-size: 24px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .page-sub { color: #64748b; font-size: 14px; font-weight: 600; }
    
    .btn-primary { background: #0284c7; color: #fff; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; font-family: inherit; }
    .btn-primary:hover { background: #0369a1; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(2,132,199,0.2); }
    
    /* Content */
    .content-area { padding: 32px 40px; display: flex; gap: 32px; }
    
    /* Announcement cards */
    .announcements-list { flex: 1; display: flex; flex-direction: column; gap: 16px; }
    .ann-card {
      background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
      padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      transition: 0.2s;
    }
    .ann-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); transform: translateY(-1px); }
    .ann-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 12px; }
    .ann-title { font-family: 'Outfit'; font-size: 17px; font-weight: 800; color: #0f172a; }
    .ann-body { font-size: 14px; color: #475569; font-weight: 600; line-height: 1.6; margin-bottom: 14px; }
    .ann-footer { display: flex; justify-content: space-between; align-items: center; }
    .ann-meta { display: flex; gap: 10px; align-items: center; }
    .badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 800; }
    .badge-academic { background: #dbeafe; color: #1d4ed8; }
    .badge-administrative { background: #fef3c7; color: #92400e; }
    .badge-events { background: #d1fae5; color: #065f46; }
    .badge-emergency { background: #fee2e2; color: #991b1b; }
    .badge-general { background: #f1f5f9; color: #475569; }
    .ann-date { font-size: 12px; color: #94a3b8; font-weight: 600; }
    
    .btn-delete { background: #fee2e2; color: #ef4444; border: none; padding: 8px 16px; border-radius: 8px; font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit; transition: 0.2s; }
    .btn-delete:hover { background: #fecaca; }
    
    .empty-state { text-align: center; padding: 60px 24px; color: #94a3b8; }
    .empty-icon { font-size: 48px; margin-bottom: 16px; }
    .empty-text { font-family: 'Outfit'; font-size: 20px; font-weight: 800; color: #cbd5e1; margin-bottom: 8px; }
    .empty-sub { font-size: 14px; font-weight: 600; }

    /* Add Form Panel */
    .add-panel {
      width: 320px; flex-shrink: 0;
    }
    .form-card {
      background: #fff; border-radius: 20px; border: 1px solid #e2e8f0;
      padding: 28px; box-shadow: 0 4px 16px rgba(0,0,0,0.04); position: sticky; top: 0;
    }
    .form-card-title { font-family: 'Outfit'; font-size: 18px; font-weight: 800; color: #0f172a; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 12px; font-weight: 800; color: #475569; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-input {
      width: 100%; padding: 12px 14px; background: #f8fafc; border: 1px solid #cbd5e1;
      border-radius: 10px; font-size: 14px; outline: none; font-family: inherit; transition: 0.2s; color: #0f172a;
    }
    .form-input:focus { background: #fff; border-color: #0284c7; box-shadow: 0 0 0 3px rgba(2,132,199,0.1); }
    textarea.form-input { resize: vertical; min-height: 100px; }
    select.form-input { cursor: pointer; }
    
    /* Modal */
    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15,23,42,0.5); backdrop-filter: blur(4px);
      display: none; align-items: center; justify-content: center; z-index: 100;
    }
    .modal-box { background: #fff; border-radius: 24px; width: 100%; max-width: 480px; padding: 32px; box-shadow: 0 25px 50px rgba(0,0,0,0.1); animation: slideUp 0.3s ease; }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .modal-title { font-family: 'Outfit'; font-size: 22px; font-weight: 800; margin-bottom: 12px; }
    .modal-body { font-size: 15px; color: #475569; font-weight: 600; margin-bottom: 28px; }
    .modal-actions { display: flex; gap: 12px; justify-content: flex-end; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 700; font-size: 14px; cursor: pointer; font-family: inherit; }
    .btn-danger { background: #ef4444; color: #fff; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 800; font-size: 14px; cursor: pointer; font-family: inherit; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sb-logo-box">
      <img src="/images/icons/logo.jpg" alt="CHCC" class="sb-logo">
      <div class="sb-title">CHCC<br><span style="color:#38bdf8; font-size:11px;">ADMINISTRATION</span></div>
    </div>
    <nav>
      <a href="/admin/students" class="nav-link">🎓 Student Roster</a>
      <a href="/admin/announcements" class="nav-link active">📢 Announcements</a>
      <a href="/admin/campus" class="nav-link">🏛️ Campus Records</a>
      <a href="/admin/settings" class="nav-link">⚙️ System Configuration</a>
    </nav>
    <div class="sb-footer">
      <div style="font-size:12px; color:#94a3b8; font-weight:700; margin-bottom:12px; text-align:center;">Logged in as Admin</div>
      <a href="/logout" class="logout-btn">Secure Logout</a>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar">
      <div>
        <div class="page-title">Announcements</div>
        <div class="page-sub">Post and manage school-wide announcements visible to all students.</div>
      </div>
    </div>

    <div class="content-area">
      <!-- Announcements List -->
      <div class="announcements-list">
        <% if (announcements.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">📢</div>
          <div class="empty-text">No Announcements Yet</div>
          <div class="empty-sub">Use the form on the right to post your first announcement.</div>
        </div>
        <% } %>
        <% announcements.forEach(function(ann) { %>
        <div class="ann-card">
          <div class="ann-header">
            <div class="ann-title"><%= ann.title %></div>
          </div>
          <div class="ann-body"><%= ann.body %></div>
          <div class="ann-footer">
            <div class="ann-meta">
              <span class="badge badge-<%= ann.category.toLowerCase() %>"><%= ann.category %></span>
              <span class="ann-date">📅 <%= ann.created_at %></span>
            </div>
            <button class="btn-delete" onclick="confirmDelete(<%= ann.id %>, '<%= ann.title.replace(/'/g, '') %>')">Delete</button>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- Add Announcement Form -->
      <div class="add-panel">
        <div class="form-card">
          <div class="form-card-title">📝 Post Announcement</div>
          <form action="/admin/announcements/add" method="POST">
            <div class="form-group">
              <label class="form-label" for="annTitle">Title</label>
              <input type="text" id="annTitle" name="title" class="form-input" placeholder="e.g. Midterm Exam Schedule" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="annBody">Message</label>
              <textarea id="annBody" name="body" class="form-input" placeholder="Write the announcement details here..." required></textarea>
            </div>
            <div class="form-group">
              <label class="form-label" for="annCategory">Category</label>
              <select id="annCategory" name="category" class="form-input">
                <option value="General">General</option>
                <option value="Academic">Academic</option>
                <option value="Administrative">Administrative</option>
                <option value="Events">Events</option>
                <option value="Emergency">Emergency</option>
              </select>
            </div>
            <button type="submit" id="postAnnBtn" class="btn-primary" style="width:100%; padding:14px;">Post Announcement</button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <!-- Delete Confirm Modal -->
  <div id="deleteModal" class="modal-overlay" onclick="closeDeleteModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
      <div class="modal-title">⚠️ Delete Announcement</div>
      <div class="modal-body" id="deleteModalBody">Are you sure you want to delete this announcement? This cannot be undone.</div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
        <form id="deleteForm" action="/admin/announcements/delete" method="POST" style="display:inline;">
          <input type="hidden" name="announcementId" id="deleteIdInput">
          <button type="submit" class="btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    function confirmDelete(id, title) {
      document.getElementById('deleteIdInput').value = id;
      document.getElementById('deleteModalBody').textContent = `Are you sure you want to delete "${title}"? This cannot be undone.`;
      document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDeleteModal() {
      document.getElementById('deleteModal').style.display = 'none';
    }
  </script>
</body>
</html>
