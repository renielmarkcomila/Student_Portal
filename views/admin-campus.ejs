<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Records | CHCC Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Nunito', sans-serif; background: #f8fafc; color: #0f172a; height: 100vh; display: flex; overflow: hidden; }
    /* Sidebar */
    .sidebar { width: 250px; background: #1e293b; color: #fff; display: flex; flex-direction: column; padding: 24px 16px; z-index: 10; }
    .sb-logo-box { display: flex; gap: 12px; align-items: center; margin-bottom: 40px; padding: 0 10px; }
    .sb-logo { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
    .sb-title { font-family: 'Outfit'; font-size: 14px; font-weight: 800; line-height: 1.2; letter-spacing: 0.5px; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 12px; color: #94a3b8; text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 6px; transition: 0.2s; }
    .nav-link:hover { background: #334155; color: #fff; }
    .nav-link.active { background: #38bdf8; color: #0f172a; }
    .sb-footer { margin-top: auto; border-top: 1px solid #334155; padding-top: 24px; }
    .logout-btn { display: block; width: 100%; text-align: center; padding: 10px; background: #ef4444; color: #fff; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 14px; transition: 0.2s; }
    .logout-btn:hover { background: #dc2626; }
    /* Main */
    .main-content { flex: 1; display: flex; flex-direction: column; overflow-y: auto; }
    .topbar { background: #fff; padding: 24px 40px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
    .page-title { font-family: 'Outfit'; font-size: 24px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .page-sub { color: #64748b; font-size: 14px; font-weight: 600; }
    .content-area { display: flex; align-items: center; justify-content: center; flex: 1; flex-direction: column; }
    .icon-huge { font-size: 64px; margin-bottom: 24px; }
    .coming-soon { font-family: 'Outfit'; font-size: 28px; font-weight: 800; color: #0f172a; margin-bottom: 8px; }
    .desc { color: #64748b; font-size: 15px; font-weight: 600; text-align: center; max-width: 400px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sb-logo-box">
      <img src="/images/icons/logo.jpg" alt="CHCC" class="sb-logo">
      <div class="sb-title">CHCC<br><span style="color:#38bdf8; font-size:11px;">ADMINISTRATION</span></div>
    </div>
    <nav>
      <a href="/admin/students" class="nav-link">🎓 Student Roster</a>
      <a href="/admin/campus" class="nav-link active">🏛️ Campus Records</a>
      <a href="/admin/settings" class="nav-link">⚙️ System Configuration</a>
    </nav>
    <div class="sb-footer">
      <div style="font-size:12px; color:#94a3b8; font-weight:700; margin-bottom:12px; text-align:center;">Logged in as Admin</div>
      <a href="/logout" class="logout-btn">Secure Logout</a>
    </div>
  </aside>
  <main class="main-content">
    <div class="topbar">
      <div>
        <div class="page-title">Campus Records</div>
        <div class="page-sub">Institutional archives and facility administration module.</div>
      </div>
    </div>
    <div class="content-area">
      <div class="icon-huge">🚧</div>
      <div class="coming-soon">Module Under Construction</div>
      <div class="desc">The Campus Records archive is currently being developed and will be available in the next software update.</div>
    </div>
  </main>
</body>
</html>
