<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | CHCC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Nunito', sans-serif;
      background: #f8fafc;
      color: #0f172a;
      height: 100vh;
      display: flex;
      overflow: hidden;
    }
    
    /* Layout */
    .sidebar {
      width: 250px;
      background: #1e293b;
      color: #fff;
      display: flex; flex-direction: column;
      padding: 24px 16px;
      z-index: 10;
    }
    .sb-logo-box { display: flex; gap: 12px; align-items: center; margin-bottom: 40px; padding: 0 10px; }
    .sb-logo { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; }
    .sb-title { font-family: 'Outfit'; font-size: 14px; font-weight: 800; line-height: 1.2; letter-spacing: 0.5px; }
    
    .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px; border-radius: 12px;
      color: #94a3b8; text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 6px;
      transition: 0.2s;
    }
    .nav-link:hover { background: #334155; color: #fff; }
    .nav-link.active { background: #38bdf8; color: #0f172a; }
    
    .sb-footer { margin-top: auto; border-top: 1px solid #334155; padding-top: 24px; }
    .logout-btn { display: block; width: 100%; text-align: center; padding: 10px; background: #ef4444; color: #fff; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 14px; transition: 0.2s; }
    .logout-btn:hover { background: #dc2626; }
    
    /* Main */
    .main-content {
      flex: 1; display: flex; flex-direction: column; overflow-y: auto;
    }
    .topbar {
      background: #fff; padding: 24px 40px; border-bottom: 1px solid #e2e8f0;
      display: flex; justify-content: space-between; align-items: center;
    }
    .page-title { font-family: 'Outfit'; font-size: 24px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .page-sub { color: #64748b; font-size: 14px; font-weight: 600; }
    
    .btn-primary { background: #0284c7; color: #fff; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; font-family: inherit; }
    .btn-primary:hover { background: #0369a1; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(2, 132, 199, 0.2); }
    
    /* Data Table */
    .table-wrapper { padding: 32px 40px; }
    .data-table-container {
      background: #fff; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid #e2e8f0; overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { background: #f8fafc; padding: 16px 24px; font-size: 12px; font-weight: 800; color: #475569; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #e2e8f0; }
    td { padding: 16px 24px; font-size: 14px; color: #334155; border-bottom: 1px solid #f1f5f9; font-weight: 600; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: #f8fafc; }
    
    .td-name { color: #0f172a; font-weight: 800; font-size: 15px; }
    .td-secondary { font-size: 13px; color: #64748b; margin-top: 2px; }
    .badge { background: #e0f2fe; color: #0284c7; font-size: 12px; padding: 4px 10px; border-radius: 20px; font-weight: 800; }
    
    .btn-manage { background: #f1f5f9; color: #0f172a; border: none; padding: 8px 16px; border-radius: 8px; font-weight: 700; font-size: 13px; cursor: pointer; transition: 0.2s; font-family: inherit; }
    .btn-manage:hover { background: #e2e8f0; }
    
    /* Modals */
    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.5); backdrop-filter: blur(4px);
      display: none; align-items: center; justify-content: center; z-index: 100;
    }
    .modal-box {
      background: #fff; border-radius: 24px; width: 100%; max-width: 500px; padding: 32px; box-shadow: 0 25px 50px rgba(0,0,0,0.1);
      position: relative; animation: slideUp 0.3s ease;
    }
    .modal-box.large { max-width: 700px; }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    
    .modal-close { position: absolute; top: 24px; right: 24px; background: none; border: none; font-size: 24px; color: #94a3b8; cursor: pointer; line-height: 1; }
    .modal-close:hover { color: #0f172a; }
    .modal-title { font-family: 'Outfit'; font-size: 24px; font-weight: 800; margin-bottom: 24px; color: #0f172a; }
    
    /* Forms inside Modal */
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 13px; font-weight: 800; color: #475569; margin-bottom: 8px; }
    .form-input { width: 100%; padding: 14px 16px; background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 12px; font-size: 15px; outline: none; font-family: inherit; transition: 0.2s; }
    .form-input:focus { background: #fff; border-color: #0284c7; box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1); }
    
    /* Action Grid inside Manage Modal */
    .student-modal-header { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid #e2e8f0; }
    .sm-avatar { width: 64px; height: 64px; border-radius: 50%; background: #e0f2fe; color: #0284c7; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 800; font-family: 'Outfit'; }
    .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    
    .action-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; cursor: pointer; transition: 0.2s; text-align: left; }
    .action-card:hover { border-color: #0284c7; background: #f0f9ff; transform: translateY(-2px); }
    .ac-icon { font-size: 24px; margin-bottom: 12px; }
    .ac-title { font-size: 16px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .ac-desc { font-size: 13px; color: #64748b; font-weight: 600; line-height: 1.4; }
    
    .action-card.danger { border-color: #fecaca; background: #fff5f5; }
    .action-card.danger:hover { background: #fef2f2; border-color: #ef4444; }
    .action-card.danger .ac-title { color: #ef4444; }
  </style>
</head>
<body>
  
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sb-logo-box">
      <img src="/images/icons/logo.jpg" alt="CHCC" class="sb-logo">
      <div class="sb-title">CHCC<br><span style="color:#38bdf8; font-size:11px;">ADMINISTRATION</span></div>
    </div>
    
    <nav>
      <a href="/admin/students" class="nav-link active">🎓 Student Roster</a>
      <a href="/admin/announcements" class="nav-link">📢 Announcements</a>
      <a href="/admin/campus" class="nav-link">🏛️ Campus Records</a>
      <a href="/admin/settings" class="nav-link">⚙️ System Configuration</a>
    </nav>
    
    <div class="sb-footer">
      <div style="font-size:12px; color:#94a3b8; font-weight:700; margin-bottom:12px; text-align:center;">Logged in as Admin</div>
      <a href="/logout" class="logout-btn">Secure Logout</a>
    </div>
  </aside>
  
  <!-- Main -->
  <main class="main-content">
    <div class="topbar">
      <div>
        <div class="page-title">Admissions Directory</div>
        <div class="page-sub">Manage institutional records and access student details securely.</div>
      </div>
      <button class="btn-primary" onclick="openModal('addModal')">+ Initiate New Admission</button>
    </div>
    
    <div class="table-wrapper">
      <div class="data-table-container">
        <table>
          <thead>
            <tr>
              <th>Applicant</th>
              <th>Portal ID & Course</th>
              <th>Contact Email</th>
              <th>Account Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(student) { %>
            <tr>
              <td>
                <div class="td-name"><%= student.name %></div>
                <div class="td-secondary">Total Units: <%= student.totalUnits || 0 %></div>
              </td>
              <td>
                <div style="color:#0f172a; font-weight:800; font-size:14px;"><%= student.studentNumber %></div>
                <div class="td-secondary"><%= student.course || 'Unassigned' %></div>
              </td>
              <td><%= student.email %></td>
              <td><span class="badge">Active Record</span></td>
              <td><button class="btn-manage"
                data-id="<%= student.id %>"
                data-name="<%= student.name.replace(/"/g, '&quot;') %>"
                data-snum="<%= student.studentNumber %>"
                data-course="<%= (student.course || '').replace(/"/g, '&quot;') %>"
                data-email="<%= (student.email || '').replace(/"/g, '&quot;') %>"
                data-year="<%= student.year || 1 %>"
                data-subjects='<%- JSON.stringify(student.subjects || []) %>'
                onclick="handleManageClick(this)">Manage Record</button></td>
            </tr>
            <% }); %>
            <% if(students.length === 0) { %>
            <tr><td colspan="5" style="text-align:center; padding:32px; color:#94a3b8;">No records found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
  
  <!-- Add Student Modal -->
  <div id="addModal" class="modal-overlay" onclick="closeModals()">
    <div class="modal-box" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="closeModals()">&times;</button>
      <div class="modal-title">Create New Admission</div>
      <form action="/admin/add" method="POST">
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" class="form-input" placeholder="e.g. DOE, John" required>
        </div>
        <div class="form-group">
          <label class="form-label">Portal ID (Student Number)</label>
          <input type="text" name="studentNumber" class="form-input" placeholder="e.g. 58062024" required>
        </div>
        <div class="form-group">
          <label class="form-label">Institutional Email</label>
          <input type="email" name="email" class="form-input" placeholder="e.g. john@chcc.edu.ph" required>
        </div>
        <div class="form-group">
          <label class="form-label">Initial Password</label>
          <input type="text" name="password" class="form-input" placeholder="Temporary password" required>
        </div>
        <div class="form-group">
          <label class="form-label">Program Course</label>
          <input type="text" name="course" class="form-input" placeholder="e.g. Bachelor of Science in Computer Science" required>
        </div>
        <button type="submit" class="btn-primary" style="width:100%; margin-top:16px; padding:16px;">Provision Account</button>
      </form>
    </div>
  </div>
  
  <!-- Manage Master Modal -->
  <div id="manageModal" class="modal-overlay" onclick="closeModals()">
    <div class="modal-box large" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="closeModals()">&times;</button>
      
      <div class="student-modal-header">
        <div class="sm-avatar" id="mmAvatar">X</div>
        <div>
          <div class="modal-title" style="margin-bottom:4px;" id="mmName">Student Name</div>
          <div style="font-size:14px; font-weight:700; color:#64748b;" id="mmMeta">ID - Course</div>
        </div>
      </div>
      
      <div class="action-grid">
        <div class="action-card" onclick="openSubModal('subjectsFormModal')">
          <div class="ac-icon">📚</div>
          <div class="ac-title">Edit Subjects</div>
          <div class="ac-desc">Assign curricular subjects and update total term units.</div>
        </div>
        <div class="action-card" onclick="openSubModal('gradeEntryModal')">
          <div class="ac-icon">📝</div>
          <div class="ac-title">Enter Grades</div>
          <div class="ac-desc">Submit midterm, finals, and final grade for each subject.</div>
        </div>
        <div class="action-card" onclick="openSubModal('editStudentModal')">
          <div class="ac-icon">✏️</div>
          <div class="ac-title">Edit Student Info</div>
          <div class="ac-desc">Update student name, course, year level, and email.</div>
        </div>
        <form id="purgeForm" action="/admin/purge" method="POST" style="margin:0; padding:0; display:block;">
          <input type="hidden" name="studentId" id="purgeIdInput">
          <div class="action-card danger" onclick="if(confirm('Are you absolutely sure? This will permanently delete the student and all their grades.')) { document.getElementById('purgeForm').submit(); }">
            <div class="ac-icon">⚠️</div>
            <div class="ac-title">Purge Account</div>
            <div class="ac-desc">Permanently delete this student account and all affiliated data.</div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Grades Modal -->
  <div id="gradesModal" class="modal-overlay" style="z-index: 105;" onclick="openModal('manageModal')">
    <div class="modal-box large" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="openModal('manageModal')">&times;</button>
      <div class="modal-title">Academic Grades</div>
      <p style="color:#64748b; font-size:14px; font-weight:600; margin-bottom:20px;">Viewing grades for <span id="gradesStudentName" style="color:#0f172a;"></span>.</p>
      <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
          <tr style="background:#f8fafc;">
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Subject</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Midterm</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Finals</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Final Grade</th>
          </tr>
        </thead>
        <tbody id="gradesTableBody">
        </tbody>
      </table>
      <div style="margin-top:16px; padding:12px 16px; background:#f0f9ff; border-radius:12px; font-size:13px; color:#0369a1; font-weight:700;">⚠️ Grades are pending submission by subject instructors.</div>
    </div>
  </div>

  <!-- Attendance Modal -->
  <div id="attendanceModal" class="modal-overlay" style="z-index: 105;" onclick="openModal('manageModal')">
    <div class="modal-box large" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="openModal('manageModal')">&times;</button>
      <div class="modal-title">Attendance Log</div>
      <p style="color:#64748b; font-size:14px; font-weight:600; margin-bottom:20px;">Attendance record for <span id="attendStudentName" style="color:#0f172a;"></span>.</p>
      <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
          <tr style="background:#f8fafc;">
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Subject</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Present</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Absent</th>
            <th style="padding:12px 16px; text-align:left; color:#475569; font-size:12px; text-transform:uppercase; letter-spacing:1px; border-bottom:1px solid #e2e8f0;">Rate</th>
          </tr>
        </thead>
        <tbody id="attendTableBody">
        </tbody>
      </table>
    </div>
  </div>

  <!-- Edit Subjects Sub-Modal -->
  <div id="subjectsFormModal" class="modal-overlay" style="z-index: 105;" onclick="openModal('manageModal')">
    <div class="modal-box" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="openModal('manageModal')">&times;</button>
      <div class="modal-title">Subject Assignment</div>
      <p style="color:#64748b; font-size:14px; font-weight:600; margin-bottom:20px;">
        Assign subjects to <span id="subjName" style="color:#0f172a;"></span>.
      </p>
      <form action="/admin/subjects" method="POST">
        <input type="hidden" name="studentId" id="subjIdInput">
        <div class="form-group">
          <label class="form-label">Subject Codes (Comma Separated)</label>
          <input type="text" name="subjectList" class="form-input" placeholder="e.g. CSA106, CSP111, MTE101" required>
        </div>
        <button type="submit" class="btn-primary" style="width:100%; margin-top:16px;">Update Curriculum Data</button>
      </form>
    </div>
  </div>

  <!-- Grade Entry Modal -->
  <div id="gradeEntryModal" class="modal-overlay" style="z-index: 105;" onclick="openModal('manageModal')">
    <div class="modal-box large" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="openModal('manageModal')">&times;</button>
      <div class="modal-title">Enter Grades</div>
      <p style="color:#64748b; font-size:14px; font-weight:600; margin-bottom:20px;">
        Enter grades for <span id="gradeStudentName" style="color:#0f172a;"></span>.
      </p>
      <form action="/admin/grades" method="POST">
        <input type="hidden" name="studentId" id="gradeStudentIdInput">
        <div class="form-group">
          <label class="form-label">Select Subject</label>
          <select name="subjectCode" id="gradeSubjectSelect" class="form-input" onchange="updateSubjectName(this)" required>
            <option value="">— Choose a subject —</option>
          </select>
          <input type="hidden" name="subjectName" id="gradeSubjectNameInput">
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px;">
          <div class="form-group">
            <label class="form-label">Midterm Grade</label>
            <input type="text" name="midterm" id="gradeMidterm" class="form-input" placeholder="e.g. 1.5" required>
          </div>
          <div class="form-group">
            <label class="form-label">Finals Grade</label>
            <input type="text" name="finals" id="gradeFinals" class="form-input" placeholder="e.g. 1.75" required>
          </div>
          <div class="form-group">
            <label class="form-label">Final Grade</label>
            <input type="text" name="finalGrade" id="gradeFinal" class="form-input" placeholder="e.g. 1.75" required>
          </div>
        </div>
        <button type="submit" class="btn-primary" style="width:100%; margin-top:8px;">Save Grades</button>
      </form>
    </div>
  </div>

  <!-- Edit Student Info Modal -->
  <div id="editStudentModal" class="modal-overlay" style="z-index: 105;" onclick="openModal('manageModal')">
    <div class="modal-box" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="openModal('manageModal')">&times;</button>
      <div class="modal-title">Edit Student Information</div>
      <form action="/admin/edit" method="POST">
        <input type="hidden" name="studentId" id="editStudentIdInput">
        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" id="editName" class="form-input" placeholder="e.g. DOE, John" required>
        </div>
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" id="editEmail" class="form-input" placeholder="e.g. john@chcc.edu.ph" required>
        </div>
        <div class="form-group">
          <label class="form-label">Program / Course</label>
          <input type="text" name="course" id="editCourse" class="form-input" placeholder="e.g. Bachelor of Science in Computer Science" required>
        </div>
        <div class="form-group">
          <label class="form-label">Year Level</label>
          <select name="year" id="editYear" class="form-input">
            <option value="1">1st Year</option>
            <option value="2">2nd Year</option>
            <option value="3">3rd Year</option>
            <option value="4">4th Year</option>
          </select>
        </div>
        <button type="submit" class="btn-primary" style="width:100%; margin-top:8px;">Save Changes</button>
      </form>
    </div>
  </div>

  <script>
    let activeStudentId = null;
    let activeStudentName = '';
    let activeStudentSubjects = [];
    let activeStudentData = {};

    function openModal(id) {
      document.querySelectorAll('.modal-overlay').forEach(el => el.style.display = 'none');
      document.getElementById(id).style.display = 'flex';
    }
    
    function closeModals() {
      document.querySelectorAll('.modal-overlay').forEach(el => el.style.display = 'none');
    }
    
    function handleManageClick(btn) {
      const id = btn.dataset.id;
      const name = btn.dataset.name;
      const sNum = btn.dataset.snum;
      const course = btn.dataset.course;
      const email = btn.dataset.email || '';
      const year  = btn.dataset.year  || '1';
      let subjects = [];
      try { subjects = JSON.parse(btn.dataset.subjects); } catch(e) {}
      activeStudentData = { id, name, email, course, year, subjects };
      openManageModal(id, name, sNum, course, subjects, email, year);
    }

    function openManageModal(id, name, sNum, course, subjects, email, year) {
      activeStudentId = id;
      activeStudentName = name;
      activeStudentSubjects = subjects || [];
      
      document.getElementById('mmAvatar').innerText = name.charAt(0).toUpperCase();
      document.getElementById('mmName').innerText = name;
      document.getElementById('mmMeta').innerText = `${sNum} — ${course || 'Unassigned'}`;
      document.getElementById('purgeIdInput').value = id;
      openModal('manageModal');
    }
    
    function openSubModal(id) {
      // subjects form
      if (document.getElementById('subjIdInput')) {
        document.getElementById('subjIdInput').value = activeStudentId;
        document.getElementById('subjName').innerText = activeStudentName;
      }
      // grade entry form
      if (id === 'gradeEntryModal') {
        document.getElementById('gradeStudentIdInput').value = activeStudentId;
        document.getElementById('gradeStudentName').innerText = activeStudentName;
        // Populate subject dropdown
        const sel = document.getElementById('gradeSubjectSelect');
        sel.innerHTML = '<option value="">— Choose a subject —</option>';
        activeStudentSubjects.forEach(function(s) {
          const opt = document.createElement('option');
          opt.value = s.code;
          opt.dataset.name = s.name;
          opt.textContent = s.code + ' — ' + s.name;
          sel.appendChild(opt);
        });
        if (activeStudentSubjects.length === 0) {
          sel.innerHTML = '<option value="">No subjects assigned yet</option>';
        }
        document.getElementById('gradeSubjectNameInput').value = '';
      }
      // edit student form
      if (id === 'editStudentModal') {
        document.getElementById('editStudentIdInput').value = activeStudentData.id;
        document.getElementById('editName').value  = activeStudentData.name || '';
        document.getElementById('editEmail').value = activeStudentData.email || '';
        document.getElementById('editCourse').value = activeStudentData.course || '';
        const yr = document.getElementById('editYear');
        yr.value = activeStudentData.year || '1';
      }
      openModal(id);
    }

    function updateSubjectName(sel) {
      const opt = sel.options[sel.selectedIndex];
      document.getElementById('gradeSubjectNameInput').value = opt.dataset.name || '';
    }
  </script>
</body>
</html>
