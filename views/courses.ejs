<%- include('partials/header', { title: 'Courses', page: 'courses', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">My Courses</div>
      <div class="banner-sub">View your enrolled subjects and course details</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <!-- Courses Content -->
  <div class="content-row">
    <div class="left-col">
      <div class="section-title">Enrolled Subjects - <%= student.semester %> AY <%= student.academicYear %></div>
      <div class="course-cards">
        <% (student.subjects || []).forEach(function(subject, i) { %>
        <div class="course-card <%= i % 2 === 0 ? 'purple' : 'lavender' %>">
          <div>
            <div class="course-name"><%= subject.code %> - <%= subject.name %></div>
            <div style="font-size: 12px; color: #666; margin-top: 4px;">Section: <%= subject.section %> | Lec Units: <%= subject.lecUnits %> | Lab Units: <%= subject.labUnits %></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="right-col">
      <div class="section-title">Course Instructors</div>
      <%
        var instrColors = [
          { bg: '#fca5a5', color: '#7f1d1d' },
          { bg: '#93c5fd', color: '#1e3a5f' },
          { bg: '#6b7280', color: '#f9fafb' }
        ];
      %>
      <% (student.instructors || []).forEach(function(instr, i) { %>
      <% var style = instrColors[i] || instrColors[0]; %>
      <div class="notice-item">
        <div style="display: flex; align-items: center; gap: 12px;">
          <% if (instr.name === 'Sir Simora') { %>
          <img src="/images/avatars/sir_simora.jpg" alt="<%= instr.name %>" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid <%= style.bg %>;">
          <% } else { %>
          <div class="instr-avatar" style="background:<%= style.bg %>; color:<%= style.color %>;">
            <%= instr.name.split(' ').map(function(n){ return n[0]; }).join('') %>
          </div>
          <% } %>
          <div>
            <div class="notice-item-title"><%= instr.name %></div>
            <div class="notice-item-body">Instructor</div>
          </div>
        </div>
      </div>
      <% }); %>

      <div style="margin-top: 24px;">
        <div class="section-title">Course Statistics</div>
        <div class="notice-item">
          <div class="notice-item-title">Total Subjects</div>
          <div class="notice-item-body"><%= (student.subjects || []).length %> subjects enrolled</div>
        </div>
        <div class="notice-item">
          <div class="notice-item-title">Total Units</div>
          <div class="notice-item-body"><%= student.totalUnits %> units this semester</div>
        </div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>