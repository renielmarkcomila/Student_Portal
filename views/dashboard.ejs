<%- include('partials/header', { title: 'Dashboard', page: 'dashboard', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">Welcome back, <%= student.name.split(',')[1] ? student.name.split(',')[1].trim().split(' ')[0] : student.name.split(' ')[0] %>!</div>
      <div class="banner-sub"><%= student.semester %> - AY <%= student.academicYear %></div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <!-- Content Row -->
  <div class="content-row">
    <div class="left-col">

      <!-- Student Info -->
      <div>
        <div class="section-title">Student Information</div>
        <div class="notice-item">
          <div class="notice-item-title"><%= student.name %></div>
          <div class="notice-item-body">Student Number: <%= student.studentNumber %></div>
          <div class="notice-item-body">Course: <%= student.course %></div>
          <div class="notice-item-body">Year Level: <%= student.year %>th Year</div>
          <div class="notice-item-body">Total Units: <%= student.totalUnits %></div>
        </div>
      </div>

      <!-- Finance -->
      <div>
        <div class="section-title">Finance</div>
        <div class="finance-cards">
          <div class="finance-card">
            <div class="finance-amount">₱<%= (student.finance && student.finance.totalAssessment ? student.finance.totalAssessment : 0).toLocaleString() %></div>
            <div class="finance-label">Total Assessment</div>
          </div>
          <div class="finance-card active">
            <div class="finance-amount">₱<%= (student.finance && student.finance.totalPaid ? student.finance.totalPaid : 0).toLocaleString() %></div>
            <div class="finance-label">Total Paid</div>
          </div>
          <div class="finance-card">
            <div class="finance-amount">₱<%= (student.finance && student.finance.outstandingBalance ? student.finance.outstandingBalance : 0).toLocaleString() %></div>
            <div class="finance-label">Outstanding Balance</div>
          </div>
        </div>
      </div>

      <!-- Enrolled Subjects -->
      <div>
        <div class="courses-header">
          <div class="section-title" style="margin-bottom:0;">Enrolled Subjects</div>
          <a href="/courses" class="see-all">See all</a>
        </div>
        <div style="height:12px;"></div>
        <div class="course-cards">
          <% (student.subjects || []).forEach(function(subject, i) { %>
          <div class="course-card <%= i % 2 === 0 ? 'purple' : 'lavender' %>">
            <div>
              <div class="course-name"><%= subject.code %> - <%= subject.name %></div>
              <div class="notice-item-body">Units: <%= subject.lecUnits %></div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

    </div>

    <!-- Right Column -->
    <div class="right-col">
      <div>
        <div class="section-title">Course instructors</div>
        <div class="instructors-row">
          <%
            var instrColors = [
              { bg: '#fca5a5', color: '#7f1d1d' }
            ];
          %>
          <% (student.instructors || []).forEach(function(instr, i) { %>
          <% var style = instrColors[i] || instrColors[0]; %>
          <% if (instr.name === 'Sir Simora') { %>
          <img src="/images/avatars/sir_simora.jpg" alt="<%= instr.name %>" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 3px solid <%= style.bg %>;">
          <% } else { %>
          <div class="instr-avatar" style="background:<%= style.bg %>; color:<%= style.color %>;">
            <%= instr.name.split(' ').map(function(n){ return n[0]; }).join('') %>
          </div>
          <% } %>
          <% }); %>
        </div>
      </div>

      <div>
        <div class="notice-header">
          <div class="section-title" style="margin-bottom:0;">Daily notice</div>
          <a href="/notice" class="see-all">See all</a>
        </div>
        <% (student.notices || []).forEach(function(notice) { %>
        <div class="notice-item">
          <div class="notice-item-title"><%= notice.title %></div>
          <div class="notice-item-body"><%= notice.body %></div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>