<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal Access | CHCC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Nunito', sans-serif;
      /* Using the exact dashboard background */
      background: linear-gradient(180deg, #7dd3fc, #38bdf8);
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    
    .login-container {
      background: #fff;
      border-radius: 24px;
      padding: 48px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 20px 40px rgba(2, 132, 199, 0.2);
    }
    
    .logo-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 24px;
    }
    
    .logo-box {
      width: 86px;
      height: 86px;
      background: #e0f2fe;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 4px solid #fff;
      box-shadow: 0 8px 16px rgba(2, 132, 199, 0.1);
    }
    
    .logo-box img {
      width: 66px;
      height: 66px;
      border-radius: 50%;
      object-fit: cover;
    }
    
    .login-title {
      text-align: center;
      font-size: 26px;
      font-weight: 800;
      color: #0369a1; /* Dashboard section-title color */
      margin-bottom: 6px;
    }
    
    .login-subtitle {
      text-align: center;
      font-size: 13px;
      color: #333;
      margin-bottom: 32px;
      font-weight: 600;
    }
    
    .form-group {
      margin-bottom: 24px;
    }
    
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 800;
      color: #0369a1;
      margin-bottom: 8px;
    }
    
    .form-input {
      width: 100%;
      padding: 16px 20px;
      background: #f0f9ff;
      border: 2px solid transparent;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      color: #333;
      outline: none;
      transition: all 0.2s;
    }
    
    .form-input:focus {
      background: #fff;
      border-color: #0284c7;
      box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.15);
    }
    
    .form-input::placeholder {
      color: #94a3b8;
    }
    
    .error-message {
      background: #fee2e2;
      color: #dc2626;
      padding: 14px 16px;
      border-radius: 12px;
      font-size: 14px;
      margin-bottom: 24px;
      display: none;
      font-weight: 700;
      text-align: center;
    }
    
    .error-message.show {
      display: block;
    }
    
    .login-btn {
      width: 100%;
      padding: 16px;
      background: #0284c7; /* Dashboard primary color */
      color: #fff;
      border: none;
      border-radius: 20px; /* Dashboard pill radius */
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.2s;
    }
    
    .login-btn:hover {
      background: #0369a1;
    }
    
    .login-footer {
      text-align: center;
      margin-top: 24px;
      font-size: 14px;
      color: #333;
      font-weight: 600;
    }
    
    .login-footer a {
      color: #0284c7;
      text-decoration: none;
      font-weight: 800;
      margin-left: 4px;
    }
    
    .login-footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="logo-wrap">
      <div class="logo-box">
        <img src="/images/icons/logo.jpg" alt="CHCC" />
      </div>
    </div>
    
    <h1 class="login-title">Student Portal Access</h1>
    <p class="login-subtitle">Concepcion Holy Cross College Inc.</p>
    
    <div class="error-message" id="errorMessage">
      Account not found or wrong email/password. Please try again.
    </div>
    
    <form id="loginForm" action="/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="username">Email/Username</label>
        <input 
          type="email" 
          id="username" 
          name="username" 
          class="form-input" 
          placeholder="e.g. johndoe@chcc.edu.ph"
          required
        />
      </div>
      
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          class="form-input" 
          placeholder="••••••••••"
          required
        />
      </div>
      
      <button type="submit" class="login-btn">Log In to Dashboard</button>
    </form>
    
    <div class="login-footer">
      <span>No account?</span>
      <a href="#">Request an institutional account from the admin office</a>
    </div>
  </div>
  
  <script>
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('error') === '1') {
      document.getElementById('errorMessage').classList.add('show');
    }
  </script>
</body>
</html>