<%- include('partials/header', { title: 'Notices & Announcements', page: 'notice', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">Notices & Announcements</div>
      <div class="banner-sub">Stay updated with the latest school announcements</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <style>
    .ann-badge {
      font-size: 11px; font-weight: 800; padding: 3px 10px;
      border-radius: 20px; white-space: nowrap; margin-left: 12px; display: inline-block;
    }
    .ann-badge-academic     { background: #dbeafe; color: #1d4ed8; }
    .ann-badge-administrative { background: #fef3c7; color: #92400e; }
    .ann-badge-events       { background: #d1fae5; color: #065f46; }
    .ann-badge-emergency    { background: #fee2e2; color: #991b1b; }
    .ann-badge-general      { background: #f1f5f9; color: #475569; }
    .ann-header-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
  </style>

  <!-- Notice Content -->
  <div class="content-row">
    <div class="left-col">
      <div class="section-title">All Announcements</div>

      <% if ((announcements || []).length === 0) { %>
      <div class="notice-item">
        <div class="notice-item-body" style="color:#94a3b8; text-align:center; padding:8px 0;">
          No announcements at this time. Check back later.
        </div>
      </div>
      <% } %>

      <% (announcements || []).forEach(function(ann) {
           var badgeClass = 'ann-badge-general';
           if (ann.category === 'Academic')         badgeClass = 'ann-badge-academic';
           else if (ann.category === 'Administrative') badgeClass = 'ann-badge-administrative';
           else if (ann.category === 'Events')       badgeClass = 'ann-badge-events';
           else if (ann.category === 'Emergency')    badgeClass = 'ann-badge-emergency';
      %>
      <div class="notice-item">
        <div class="ann-header-row">
          <div class="notice-item-title"><%= ann.title %></div>
          <span class="ann-badge <%= badgeClass %>"><%= ann.category %></span>
        </div>
        <div class="notice-item-body"><%= ann.body %></div>
        <div style="margin-top:10px; font-size:12px; color:#94a3b8; font-weight:600;">📅 <%= ann.created_at %></div>
      </div>
      <% }); %>
    </div>

    <div class="right-col">
      <div class="section-title">Notice Categories</div>
      <div class="notice-item">
        <div class="notice-item-title">📘 Academic</div>
        <div class="notice-item-body">Exam schedules, course updates, and academic policies.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">🗂️ Administrative</div>
        <div class="notice-item-body">Fee deadlines, registration dates, and office hours.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">🎉 Events</div>
        <div class="notice-item-body">Campus events, workshops, and seminars.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">🚨 Emergency</div>
        <div class="notice-item-body">Safety alerts, weather updates, and urgent notices.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">📋 General</div>
        <div class="notice-item-body">General school-wide notices and information.</div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>
