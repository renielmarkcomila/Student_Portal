<%- include('partials/header', { title: 'Notice', page: 'notice', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">Notices & Announcements</div>
      <div class="banner-sub">Stay updated with important announcements</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <!-- Notice Content -->
  <div class="content-row">
    <div class="left-col">
      <div class="section-title">All Notices</div>
      <% (student.notices || []).forEach(function(notice) { %>
      <div class="notice-item">
        <div class="notice-item-title"><%= notice.title %></div>
        <div class="notice-item-body"><%= notice.body %></div>
        <a href="/notice/<%= notice.id %>" class="notice-more">Read more</a>
      </div>
      <% }); %>

      <div class="notice-item">
        <div class="notice-item-title">Library Hours Extended</div>
        <div class="notice-item-body">The university library will remain open until 10 PM during the examination period starting from March 1st.</div>
        <a href="#" class="notice-more">Read more</a>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Campus Maintenance Notice</div>
        <div class="notice-item-body">Scheduled maintenance work will be conducted in Building A from March 5-7. Classes will be relocated to Building B.</div>
        <a href="#" class="notice-more">Read more</a>
      </div>
    </div>

    <div class="right-col">
      <div class="section-title">Notice Categories</div>
      <div class="notice-item">
        <div class="notice-item-title">Academic</div>
        <div class="notice-item-body">Exam schedules, course updates, and academic policies.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Administrative</div>
        <div class="notice-item-body">Fee deadlines, registration dates, and office hours.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Events</div>
        <div class="notice-item-body">Campus events, workshops, and seminars.</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Emergency</div>
        <div class="notice-item-body">Safety alerts, weather updates, and urgent notices.</div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>
