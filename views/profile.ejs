<%- include('partials/header', { title: 'My Profile', page: 'profile', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">My Profile</div>
      <div class="banner-sub">View and manage your personal academic information</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <!-- Profile Content -->
  <div class="content-row">
    <div class="left-col">

      <!-- Avatar & Name Card -->
      <div class="notice-item" style="display:flex; align-items:center; gap:20px; padding:24px;">
        <div style="width:72px; height:72px; border-radius:50%; background:linear-gradient(135deg,#0284c7,#38bdf8); color:#fff; display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:800; flex-shrink:0; font-family:'Nunito',sans-serif;">
          <%= (student.name || 'S').split(' ').map(n => n[0]).join('').toUpperCase() %>
        </div>
        <div>
          <div class="notice-item-title" style="font-size:20px;"><%= student.name %></div>
          <div class="notice-item-body" style="color:#0284c7; font-weight:700;">Student — <%= student.course || 'Unassigned' %></div>
        </div>
      </div>

      <div class="section-title">Personal Information</div>
      <div class="notice-item">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Full Name</div>
            <div class="notice-item-title"><%= student.name %></div>
          </div>
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Student Number</div>
            <div class="notice-item-title"><%= student.studentNumber %></div>
          </div>
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Email Address</div>
            <div class="notice-item-body"><%= student.email %></div>
          </div>
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Year Level</div>
            <div class="notice-item-body">
              <%= student.year %><% if (student.year == 1) { %>st<% } else if (student.year == 2) { %>nd<% } else if (student.year == 3) { %>rd<% } else { %>th<% } %> Year
            </div>
          </div>
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Program / Course</div>
            <div class="notice-item-body"><%= student.course || 'Not assigned' %></div>
          </div>
          <div>
            <div style="font-size:12px; font-weight:800; color:#64748b; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Semester</div>
            <div class="notice-item-body"><%= student.semester || '—' %> — AY <%= student.academicYear || '—' %></div>
          </div>
        </div>
      </div>

      <div class="section-title">Academic Summary</div>
      <div class="finance-cards">
        <div class="finance-card active">
          <div class="finance-amount"><%= student.totalUnits || 0 %></div>
          <div class="finance-label">Total Units</div>
        </div>
        <div class="finance-card">
          <div class="finance-amount"><%= (student.subjects || []).length %></div>
          <div class="finance-label">Subjects Enrolled</div>
        </div>
        <div class="finance-card">
          <div class="finance-amount"><%= student.year || 1 %></div>
          <div class="finance-label">Year Level</div>
        </div>
      </div>

    </div>

    <div class="right-col">
      <div class="section-title">Enrolled Subjects</div>
      <% if ((student.subjects || []).length === 0) { %>
      <div class="notice-item">
        <div class="notice-item-body" style="color:#94a3b8; text-align:center; padding:8px 0;">No subjects assigned yet.</div>
      </div>
      <% } %>
      <% (student.subjects || []).forEach(function(subject, i) { %>
      <div class="course-card <%= i % 2 === 0 ? 'purple' : 'lavender' %>" style="margin-bottom:10px;">
        <div>
          <div class="course-name"><%= subject.code %> — <%= subject.name %></div>
          <div class="notice-item-body">Lec Units: <%= subject.lecUnits %> | Lab Units: <%= subject.labUnits || 0 %></div>
        </div>
      </div>
      <% }); %>

      <div class="section-title" style="margin-top:24px;">Account Status</div>
      <div class="notice-item">
        <div class="notice-item-title" style="color:#16a34a;">✅ Active — Good Standing</div>
        <div class="notice-item-body">Your account is in good standing. All academic records are accessible.</div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>
