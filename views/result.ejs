<%- include('partials/header', { title: 'Results & Grades', page: 'result', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">Academic Results</div>
      <div class="banner-sub">View your grades and academic performance</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <style>
    .grade-box { background: #f8fafc; border-radius: 10px; padding: 12px; text-align: center; }
    .grade-box.has-grade { background: #f0f9ff; border: 1px solid #bae6fd; }
    .grade-label { font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .grade-value { font-size: 18px; font-weight: 800; color: #cbd5e1; }
    .grade-value.filled { color: #0284c7; }
    .grade-value.final-filled { color: #0369a1; }
    .grade-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-top: 12px; }
  </style>

  <!-- Result Content -->
  <div class="content-row">
    <div class="left-col">
      <div class="section-title"><%= student.semester %> <%= student.academicYear %> — Subject Grades</div>

      <% if ((student.subjects || []).length === 0) { %>
      <div class="notice-item">
        <div class="notice-item-body" style="color:#94a3b8; text-align:center; padding:8px 0;">No subjects enrolled yet.</div>
      </div>
      <% } %>

      <% (student.subjects || []).forEach(function(subject) {
           var gradeRow = (grades || []).find(function(g) { return g.subject_code === subject.code; });
           var midterm    = gradeRow && gradeRow.midterm    ? gradeRow.midterm    : '';
           var finals     = gradeRow && gradeRow.finals     ? gradeRow.finals     : '';
           var finalGrade = gradeRow && gradeRow.final_grade ? gradeRow.final_grade : '';
      %>
      <div class="notice-item">
        <div class="notice-item-title"><%= subject.code %> — <%= subject.name %></div>
        <div class="grade-grid">
          <div class="grade-box">
            <div class="grade-label">Midterm</div>
            <div class="grade-value <%= midterm ? 'filled' : '' %>"><%= midterm || '—' %></div>
          </div>
          <div class="grade-box">
            <div class="grade-label">Finals</div>
            <div class="grade-value <%= finals ? 'filled' : '' %>"><%= finals || '—' %></div>
          </div>
          <div class="grade-box <%= finalGrade ? 'has-grade' : '' %>">
            <div class="grade-label">Final Grade</div>
            <div class="grade-value <%= finalGrade ? 'final-filled' : '' %>"><%= finalGrade || '—' %></div>
          </div>
        </div>
        <div class="notice-item-body" style="margin-top:10px;">
          Lec Units: <%= subject.lecUnits %> | Lab Units: <%= subject.labUnits || 0 %>
          <% if (!gradeRow) { %>&nbsp;·&nbsp;<span style="color:#f59e0b; font-weight:700;">Grades pending</span><% } %>
        </div>
      </div>
      <% }); %>
    </div>

    <div class="right-col">
      <div class="section-title">Academic Standing</div>
      <div class="notice-item">
        <div class="notice-item-title">Status</div>
        <div class="notice-item-body" style="color: #34d399; font-weight: 700;">Enrolled — Good Standing</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Total Units In Progress</div>
        <div class="notice-item-body"><%= student.totalUnits || 0 %> units this semester</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Subjects Enrolled</div>
        <div class="notice-item-body"><%= (student.subjects || []).length %> subjects</div>
      </div>

      <div style="margin-top: 24px;">
        <div class="section-title">Grading Scale</div>
        <div class="notice-item">
          <div class="notice-item-body">1.0 — Excellent (97–100%)</div>
          <div class="notice-item-body">1.25 — Superior (94–96%)</div>
          <div class="notice-item-body">1.5 — Very Good (91–93%)</div>
          <div class="notice-item-body">1.75 — Good (88–90%)</div>
          <div class="notice-item-body">2.0 — Satisfactory (85–87%)</div>
          <div class="notice-item-body">2.25 — Fairly Satisfactory (82–84%)</div>
          <div class="notice-item-body">2.5 — Average (79–81%)</div>
          <div class="notice-item-body">2.75 — Passing (76–78%)</div>
          <div class="notice-item-body">3.0 — Conditional Failure (75%)</div>
          <div class="notice-item-body">5.0 — Failed (Below 75%)</div>
        </div>
      </div>

      <div style="margin-top: 24px;">
        <div class="section-title">Examination Schedule</div>
        <div class="notice-item">
          <div class="notice-item-title">Midterm Exams</div>
          <div class="notice-item-body">March 16–21, 2026</div>
        </div>
        <div class="notice-item">
          <div class="notice-item-title">Final Exams</div>
          <div class="notice-item-body">May 25 – June 3, 2026</div>
        </div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>