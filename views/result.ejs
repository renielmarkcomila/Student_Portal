<%- include('partials/header', { title: 'Result', page: 'result', student }) %>

  <!-- Banner -->
  <div class="banner">
    <div class="banner-text">
      <div class="banner-date"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      <div class="banner-title">Academic Results</div>
      <div class="banner-sub">View your grades and academic performance</div>
    </div>
    <div class="banner-deco">
      <img src="/images/icons/logo.jpg" alt="CHCC" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; opacity: 0.9;">
    </div>
  </div>

  <!-- Result Content -->
  <div class="content-row">
    <div class="left-col">
      <div class="section-title"><%= student.semester %> <%= student.academicYear %> Results</div>
      <div class="finance-cards">
        <div class="finance-card active">
          <div class="finance-amount">--</div>
          <div class="finance-label">Current GPA</div>
        </div>
        <div class="finance-card">
          <div class="finance-amount">3.50</div>
          <div class="finance-label">Previous GPA</div>
        </div>
        <div class="finance-card">
          <div class="finance-amount">90%</div>
          <div class="finance-label">Attendance</div>
        </div>
      </div>

      <div style="margin-top: 24px;">
        <div class="section-title">Subject Grades (Pending)</div>
        <% (student.subjects || []).forEach(function(subject) { %>
        <div class="notice-item">
          <div class="notice-item-title"><%= subject.code %> - <%= subject.name %></div>
          <div class="notice-item-body">Grade: <strong>--</strong> | Lec Units: <%= subject.lecUnits %> | Lab Units: <%= subject.labUnits %></div>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="right-col">
      <div class="section-title">Academic Standing</div>
      <div class="notice-item">
        <div class="notice-item-title">Status</div>
        <div class="notice-item-body" style="color: #34d399; font-weight: 600;">Enrolled - Good Standing</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Total Units Earned</div>
        <div class="notice-item-body">63 units (Previous Semesters)</div>
      </div>
      <div class="notice-item">
        <div class="notice-item-title">Units In Progress</div>
        <div class="notice-item-body"><%= student.totalUnits %> units</div>
      </div>

      <div style="margin-top: 24px;">
        <div class="section-title">Grading Scale</div>
        <div class="notice-item">
          <div class="notice-item-body">A: 4.0 | A-: 3.7 | B+: 3.3 | B: 3.0 | B-: 2.7</div>
          <div class="notice-item-body">C+: 2.3 | C: 2.0 | C-: 1.7 | D: 1.0 | F: 0.0</div>
        </div>
      </div>

      <div style="margin-top: 24px;">
        <div class="section-title">Examination Schedule</div>
        <div class="notice-item">
          <div class="notice-item-title">Midterm Exams</div>
          <div class="notice-item-body">March 16-21, 2026</div>
        </div>
        <div class="notice-item">
          <div class="notice-item-title">Final Exams</div>
          <div class="notice-item-body">May 25 - June 3, 2026</div>
        </div>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>